{
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-net --allow-env --allow-ffi --allow-run=ffprobe,ffmpeg src/main.ts",
    "check": "deno check src/main.ts"
  },
  "imports": {
    "@mediabunny/server": "npm:@mediabunny/server@1.50.3",
    "mediabunny": "npm:mediabunny@1.50.3",
    "preact": "npm:preact@^10",
    "preact-render-to-string": "npm:preact-render-to-string@^6",
    "std/assert": "jsr:@std/assert@1",
    "std/path": "jsr:@std/path@1"
  },
  "fmt": {
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
